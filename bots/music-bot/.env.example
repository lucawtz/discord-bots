# ============================================================
# LOKAL TESTEN: Erstelle einen zweiten Bot im Discord Developer
# Portal (z.B. "BeatByte Dev") und trage hier dessen Token ein.
# So laeuft der Prod-Bot auf dem Server weiter, waehrend du
# lokal mit dem Dev-Bot testest.
# ============================================================
DISCORD_TOKEN=dein-bot-token-hier
CLIENT_ID=deine-application-id-hier
GUILD_ID=deine-server-id-hier

# Desktop App API
API_PORT=3001
# PFLICHT: Sicherer API Key (z.B. generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
API_KEY=

# Discord OAuth2 (fuer "Mit Discord anmelden" auf der Web App)
# Client Secret findest du im Discord Developer Portal -> OAuth2
DISCORD_CLIENT_SECRET=dein-client-secret
# Redirect URI muss auch im Developer Portal unter Redirects eingetragen werden
OAUTH_REDIRECT_URI=https://app.bytebots.de/api/auth/discord/callback

# CORS: Erlaubte Origins (kommagetrennt)
# Tauri Desktop App (tauri://localhost) ist automatisch erlaubt
# Produktion: https://bytebots.de
# Lokal: http://localhost:3001,http://localhost:5173
ALLOWED_ORIGINS=https://bytebots.de

# Music Player App
APP_URL=http://dein-server:3001
APP_DOWNLOAD_URL=

# Spotify Integration (optional, für Spotify-Playlists/Tracks/Alben)
# Erstelle eine App auf https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=deine-spotify-client-id
SPOTIFY_CLIENT_SECRET=dein-spotify-client-secret

# Optional: cookies.txt im Projektordner ablegen für YouTube-Stabilität
# Export z.B. mit Browser-Extension "Get cookies.txt LOCALLY"
