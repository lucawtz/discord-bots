# Production Overrides - werden beim Deploy automatisch in .env gesetzt
# Secrets (TOKEN, CLIENT_SECRET, etc.) werden NICHT hier gespeichert!
# Nur nicht-sensible Production-Konfiguration.

OAUTH_REDIRECT_URI=https://app.bytebots.de/api/auth/discord/callback
ALLOWED_ORIGINS=https://app.bytebots.de,https://bytebots.de
FRONTEND_URL=https://app.bytebots.de
APP_URL=https://app.bytebots.de
