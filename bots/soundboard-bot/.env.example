# ============================================================
# LOKAL TESTEN: Erstelle einen zweiten Bot im Discord Developer
# Portal (z.B. "Soundboard Dev") und trage hier dessen Token ein.
# So laeuft der Prod-Bot auf dem Server weiter, waehrend du
# lokal mit dem Dev-Bot testest.
# ============================================================
DISCORD_TOKEN=dein-bot-token-hier
CLIENT_ID=deine-client-id-hier
GUILD_ID=deine-server-id-hier

# Web-Dashboard Port (default 3000)
WEB_PORT=3002

# PFLICHT: Sicherer API Key (z.B. generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
API_KEY=

# CORS: Erlaubte Origins (kommagetrennt)
# Produktion: https://bytebots.de
# Lokal: http://localhost:3002
ALLOWED_ORIGINS=https://bytebots.de
