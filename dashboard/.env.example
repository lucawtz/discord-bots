# Dashboard Credentials
DASHBOARD_USER=admin
DASHBOARD_PASSWORD_HASH=

# Um einen Hash zu generieren, fuehre aus:
#   node -e "require('bcryptjs').hash('dein-passwort', 12).then(h => console.log(h))"
# Den Output als DASHBOARD_PASSWORD_HASH eintragen

# Port (optional, default 3000)
PORT=3000

# CORS wird ueber Nginx geregelt, kein ALLOWED_ORIGINS noetig
