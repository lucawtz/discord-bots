{
  "servers": [
    {
      "id": "oracle-prod-01",
      "name": "oracle-prod-01",
      "host": "130.61.88.80",
      "user": "ubuntu",
      "os": "Ubuntu 22.04",
      "tags": ["Production", "Docker"],
      "isLocal": true
    }
  ],
  "bots": [
    {
      "id": "beatbyte",
      "name": "BeatByte",
      "description": "Discord Music Bot",
      "service": "discord-bot",
      "icon": "music",
      "color": "#e94560",
      "server": "oracle-prod-01",
      "method": "Systemd",
      "port": 3001,
      "recovery": { "enabled": true, "maxRestarts": 5, "restartDelay": 3, "backoff": "exponential", "healthCheckUrl": null }
    },
    {
      "id": "soundboard",
      "name": "Soundboard Bot",
      "description": "Discord Soundboard",
      "service": "soundboard-bot",
      "icon": "volume-2",
      "color": "#3b82f6",
      "server": "oracle-prod-01",
      "method": "Systemd",
      "port": 3002,
      "recovery": { "enabled": true, "maxRestarts": 5, "restartDelay": 3, "backoff": "exponential", "healthCheckUrl": null }
    }
  ],
  "alerts": {
    "rules": [
      { "id": "cpu-high", "name": "CPU High", "metric": "cpu", "operator": "gt", "threshold": 80, "duration": 300, "severity": "warning", "enabled": true },
      { "id": "ram-critical", "name": "RAM Critical", "metric": "ram", "operator": "gt", "threshold": 90, "duration": 120, "severity": "critical", "enabled": true },
      { "id": "disk-low", "name": "Disk Space Low", "metric": "disk", "operator": "gt", "threshold": 80, "duration": 0, "severity": "warning", "enabled": true },
      { "id": "bot-crash", "name": "Bot Crashed", "metric": "bot_status", "operator": "eq", "threshold": "crashed", "duration": 0, "severity": "critical", "enabled": true }
    ]
  },
  "webhook": { "url": "", "enabled": false },
  "uptime": { "targets": [{ "name": "Cloudflare", "host": "1.1.1.1" }, { "name": "Google", "host": "8.8.8.8" }], "interval": 60 },
  "backups": { "directory": "/home/ubuntu/backups", "schedule": "daily", "retention": 7 }
}
